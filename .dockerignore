# .dockerignore — exclut les fichiers inutiles de l'image Docker

# Git
.git/
.gitignore

# Environnement virtuel local
.venv/
venv/
env/

# Secrets (montés via variables d'environnement en production)
.env
.env.local

# Cache Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Données dynamiques (montées via volumes en docker-compose local)
watchlist/watchlist.json
watchlist/last_scores.json
# auth/users.yaml est inclus dans l'image (seed utilisateurs sur Render sans volume)

# IDE et OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Modèles NLP lourds (non inclus par défaut)
models/
*.bin
*.pt
*.safetensors

# Logs
*.log
logs/

# Tests et docs
tests/
*.md
