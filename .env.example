# .env.example — Variables d'environnement requises
# Copiez ce fichier en .env et remplissez vos clés API
# Le fichier .env est gitignore et ne doit JAMAIS être commité

# ── Clé secrète Flask (obligatoire en production) ────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=changez_moi_en_production_valeur_aleatoire_longue

# ── NewsAPI ───────────────────────────────────────────────
# Inscription gratuite : https://newsapi.org/
NEWS_API_KEY=votre_cle_newsapi_ici

# ── Groq (LLM) ───────────────────────────────────────────
# Console Groq : https://console.groq.com/
# Modèle utilisé : llama-3.3-70b-versatile
GROQ_API_KEY=votre_cle_groq_ici

# ── Supabase (persistance comptes + watchlist) ───────────
# Laisser vide → fichiers locaux (dev sans Supabase)
# Project Settings → API → Project URL
SUPABASE_URL=
# Project Settings → API → service_role key (bypass RLS — server-side uniquement)
# Ne jamais exposer côté client. Activer RLS sur toutes les tables.
SUPABASE_SERVICE_KEY=
# Project Settings → API → anon public key (fallback dev local si service key absente)
SUPABASE_KEY=

# ── Finnhub (quote temps réel + fondamentaux) ────────────
# Compte gratuit : https://finnhub.io/ → Dashboard → API Key
# 60 appels/min, fonctionne sur Render et tout cloud
FINNHUB_API_KEY=votre_cle_finnhub_ici

# ── Twelve Data (historique OHLCV) ───────────────────────
# Compte gratuit : https://twelvedata.com/ → API Keys
# 800 appels/jour, couvre marchés US + Europe
TWELVE_DATA_API_KEY=votre_cle_twelvedata_ici

# ── Scheduler (cron-job.org) ─────────────────────────────
# Token secret pour protéger l'endpoint /scheduler/run
# Générer : python -c "import secrets; print(secrets.token_hex(24))"
CRON_SECRET=votre_token_secret_ici

# ── Resend (alertes email via HTTP — fonctionne sur Render) ──
# Compte gratuit : https://resend.com/ → API Keys (3 000 emails/mois)
# Sans domaine propre : RESEND_FROM=SDE StockDecisionEngine <onboarding@resend.dev>
# Avec domaine vérifié : RESEND_FROM=SDE <noreply@mondomaine.com>
RESEND_API_KEY=votre_cle_resend_ici
RESEND_FROM=SDE StockDecisionEngine <onboarding@resend.dev>
