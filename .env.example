# .env.example — Copiez ce fichier en .env et remplissez vos clés
# Le fichier .env est ignoré par git (.gitignore)

# NewsAPI — https://newsapi.org/
NEWS_API_KEY=

# Groq (LLM) — https://console.groq.com/keys
GROQ_API_KEY=

# SMTP Gmail (alertes email)
SMTP_PASSWORD=

# Flask
FLASK_SECRET_KEY=changez_moi_en_production
